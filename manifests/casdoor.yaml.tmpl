apiVersion: v1
kind: Namespace
metadata:
  name: __NAMESPACE__
  labels:
    app.kubernetes.io/name: casdoor
    app.kubernetes.io/instance: casdoor
---
apiVersion: v1
kind: Secret
metadata:
  name: casdoor-config
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: casdoor
    app.kubernetes.io/instance: casdoor
type: Opaque
data:
  app.conf: __APP_CONF_B64__
---
apiVersion: v1
kind: Service
metadata:
  name: casdoor
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: casdoor
    app.kubernetes.io/instance: casdoor
spec:
  type: __SERVICE_TYPE__
  selector:
    app.kubernetes.io/name: casdoor
    app.kubernetes.io/instance: casdoor
  ports:
  - name: http
    port: 8000
    targetPort: http
    protocol: TCP
__NODEPORT_HTTP_LINE__
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: casdoor
  namespace: __NAMESPACE__
  labels:
    app.kubernetes.io/name: casdoor
    app.kubernetes.io/instance: casdoor
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: casdoor
      app.kubernetes.io/instance: casdoor
  template:
    metadata:
      labels:
        app.kubernetes.io/name: casdoor
        app.kubernetes.io/instance: casdoor
    spec:
      terminationGracePeriodSeconds: 30
      containers:
      - name: casdoor
        image: __CASDOOR_IMAGE__
        imagePullPolicy: __IMAGE_PULL_POLICY__
        args:
        - __CREATE_DATABASE_ARG__
        ports:
        - name: http
          containerPort: 8000
          protocol: TCP
        env:
        - name: RUNNING_IN_DOCKER
          value: "true"
        readinessProbe:
          httpGet:
            path: /
            port: http
          initialDelaySeconds: 20
          periodSeconds: 10
          timeoutSeconds: 5
          failureThreshold: 18
        livenessProbe:
          httpGet:
            path: /
            port: http
          initialDelaySeconds: 60
          periodSeconds: 20
          timeoutSeconds: 5
          failureThreshold: 6
        resources:
          requests:
            cpu: 100m
            memory: 256Mi
          limits:
            cpu: "2"
            memory: 2Gi
        volumeMounts:
        - name: config
          mountPath: /conf/app.conf
          subPath: app.conf
          readOnly: true
      volumes:
      - name: config
        secret:
          secretName: casdoor-config
